{
  "name": "@gravitational/design-system",
  "version": "0.0.14",
  "main": "dist/index.js",
  "license": "Apache-2.0",
  "bin": {
    "design-system": "./cli/cli.js"
  },
  "scripts": {
    "prepare": "husky",
    "prebuild": "pnpm generate-theme",
    "build": "rm -rf dist && rolldown -c rolldown.config.mts && pnpm pack-release",
    "bot": "jiti bot/index.ts",
    "dev": "rolldown -c rolldown.config.mts --watch",
    "oxlint": "oxlint -c .oxlintrc.json .",
    "format-check": "pnpm format --check",
    "format": "oxfmt \"**/*.{ts,tsx,mts,md,mdx}\"",
    "lint": "pnpm oxlint && pnpm format-check",
    "type-check": "tsgo --build",
    "storybook": "storybook dev -p 6006",
    "prebuild-storybook": "pnpm generate-theme",
    "build-storybook": "storybook build",
    "test": "vitest --project=storybook && cd bot && pnpm test",
    "pack-release": "cd dist && pnpm pack --out package.tgz",
    "release": "changeset publish",
    "generate": "pnpm generate-icons && pnpm generate-props",
    "generate-check": "pnpm generate-icons --check && pnpm generate-props --check",
    "generate-icons": "jiti src/icons/generate.ts",
    "pregenerate-props": "pnpm generate-theme",
    "generate-props": "jiti src/storybook/props/generate.ts",
    "generate-theme": "chakra typegen src/themes/teleport/theme.ts --strict && jiti src/cli/generateComments.ts",
    "create-storybook-doc": "jiti src/storybook/create.ts",
    "taplo-check": "taplo fmt --check",
    "taplo-write": "taplo fmt"
  },
  "dependencies": {
    "@ark-ui/react": "^5.36.2",
    "@chakra-ui/cli": "^3.35.0",
    "@chakra-ui/react": "^3.35.0",
    "@hookform/resolvers": "^5.2.2",
    "@phosphor-icons/react": "^2.1.10",
    "next-themes": "^0.4.6",
    "react-hook-form": "^7.75.0",
    "@tanstack/react-table": "^8.21.3"
  },
  "peerDependencies": {
    "@emotion/react": ">=11",
    "@fontsource/ubuntu": "^5.2.8",
    "@tanstack/react-query": ">=5",
    "react": ">=19",
    "react-dom": ">=19",
    "tslib": "^2.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@chakra-ui/cli": "^3.26.0",
    "@chakra-ui/react": "^3.26.0",
    "@changesets/cli": "^2.31.0",
    "@changesets/get-release-plan": "^4.0.16",
    "@changesets/types": "^6.1.0",
    "@emotion/react": "^11.14.0",
    "@eslint/js": "^9.39.4",
    "@fontsource/ubuntu": "^5.2.8",
    "@mdx-js/react": "^3.1.1",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-themes": "^10.3.6",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@svitejs/changesets-changelog-github-compact": "^1.2.0",
    "@tanstack/react-query": "^5.90.2",
    "@taplo/cli": "^0.7.0",
    "@types/hast": "^3.0.4",
    "@types/node": "^24.12.2",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260505.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-plugin-testing-library": "^7.16.2",
    "globals": "^16.5.0",
    "hast": "^1.0.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "markdown-to-jsx": "^7.7.17",
    "msw": "^2.12.14",
    "msw-storybook-addon": "^2.0.6",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.16.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "prismjs": "^1.30.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rehype-github-alerts": "^4.2.0",
    "remark-gfm": "^4.0.1",
    "rolldown": "1.0.0-rc.18",
    "rollup-plugin-copy": "^3.5.0",
    "storybook": "^10.3.6",
    "tocbot": "^4.36.6",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "usehooks-ts": "^3.1.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "zod": "^4.4.3"
  },
  "packageManager": "pnpm@10.26.1+sha512.664074abc367d2c9324fdc18037097ce0a8f126034160f709928e9e9f95d98714347044e5c3164d65bd5da6c59c6be362b107546292a8eecb7999196e5ce58fa",
  "engines": {
    "node": "^24"
  },
  "storybook": {
    "title": "Teleport Design System",
    "url": "https://design.teleport.dev"
  },
  "publishConfig": {
    "directory": "dist"
  },
  "exports": {
    ".": {
      "dev": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./ubuntu.css": "./ubuntu.css"
  },
  "pnpm": {
    "overrides": {
      "undici": "^6.25.0"
    }
  },
  "msw": {
    "workerDirectory": [
      ".storybook/public"
    ]
  }
}